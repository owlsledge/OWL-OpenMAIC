# =============================================================================
# OpenMAIC Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — only configure the providers you want to use.
# You can also use server-providers.yml for configuration (see docs).
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)

OPENAI_API_KEY=
OPENAI_BASE_URL=
# Flagship: gpt-5.4-pro, gpt-5.4 | Fast/cheap: gpt-5.4-mini | Reasoning: o3, o4-mini | Stable: gpt-4o, gpt-4o-mini
OPENAI_MODELS=gpt-5.4-pro,gpt-5.4,gpt-5.4-mini,o3,o4-mini,gpt-4o,gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

GOOGLE_API_KEY=
GOOGLE_BASE_URL=
# Gemini 3.x (thinking): gemini-3.1-pro-preview, gemini-3-pro-preview, gemini-3-flash-preview | Gemini 2.5: gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite
GOOGLE_MODELS=gemini-3.1-pro-preview,gemini-3-pro-preview,gemini-3-flash-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODELS=

KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODELS=

MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODELS=

GLM_API_KEY=
GLM_BASE_URL=
GLM_MODELS=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=
SILICONFLOW_MODELS=

DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODELS=

# --- TTS (Text-to-Speech) ----------------------------------------------------
# OpenAI TTS: uses your OPENAI_API_KEY — model is gpt-4o-mini-tts (hardcoded)
#   Voices: alloy, ash, coral, echo, fable, marin, nova, onyx, sage, shimmer, verse
# Note: no Google TTS provider is implemented; use openai-tts or azure-tts for English,
#       glm-tts / qwen-tts for Mandarin.

TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=

TTS_GLM_API_KEY=
TTS_GLM_BASE_URL=

TTS_QWEN_API_KEY=
TTS_QWEN_BASE_URL=

# --- ASR (Automatic Speech Recognition) --------------------------------------

ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=

ASR_QWEN_API_KEY=
ASR_QWEN_BASE_URL=

# --- PDF Processing -----------------------------------------------------------

PDF_UNPDF_API_KEY=
PDF_UNPDF_BASE_URL=

PDF_MINERU_API_KEY=
PDF_MINERU_BASE_URL=

# --- Image Generation ---------------------------------------------------------
# nano-banana (Gemini): uses your GOOGLE_API_KEY
#   Models: gemini-3.1-flash-image-preview, gemini-3-pro-image-preview, gemini-2.5-flash-image
#   Aspect ratios: 16:9, 4:3, 1:1
# seedream: Volcengine/ByteDance API key (separate from OpenAI/Google)
# qwen-image: Alibaba DashScope API key (separate from OpenAI/Google)

IMAGE_SEEDREAM_API_KEY=
IMAGE_SEEDREAM_BASE_URL=

IMAGE_QWEN_IMAGE_API_KEY=
IMAGE_QWEN_IMAGE_BASE_URL=

# Set this to your GOOGLE_API_KEY value to enable Gemini image generation
IMAGE_NANO_BANANA_API_KEY=
IMAGE_NANO_BANANA_BASE_URL=

# --- Video Generation ---------------------------------------------------------
# veo (Google): uses your GOOGLE_API_KEY
#   Models: veo-3.1-generate-001, veo-3.1-fast-generate-001, veo-3.0-generate-001,
#           veo-3.0-fast-generate-001, veo-2.0-generate-001
#   Aspect ratios: 16:9, 1:1, 9:16 — max duration: 8s at 720p
# sora (OpenAI): uses your OPENAI_API_KEY — no models registered yet (placeholder)
# seedance / kling: third-party keys (Volcengine and Kuaishou respectively)

VIDEO_SEEDANCE_API_KEY=
VIDEO_SEEDANCE_BASE_URL=

VIDEO_KLING_API_KEY=
VIDEO_KLING_BASE_URL=

# Set this to your GOOGLE_API_KEY value to enable Veo video generation
VIDEO_VEO_API_KEY=
VIDEO_VEO_BASE_URL=

# Set this to your OPENAI_API_KEY value — Sora support is a placeholder (no models yet)
VIDEO_SORA_API_KEY=
VIDEO_SORA_BASE_URL=

# --- Web Search ---------------------------------------------------------------

TAVILY_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- Misc ---------------------------------------------------------------------

# Optional server-side default model for API routes like /api/generate-classroom
# Format: provider:modelId  —  provider must match a key in providers.ts (openai, google, anthropic, …)
# OpenAI examples:  openai:gpt-5.4-mini  openai:gpt-5.4  openai:o3
# Google examples:  google:gemini-3.1-pro-preview  google:gemini-2.5-flash
DEFAULT_MODEL=google:gemini-3.1-pro-preview

# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LLM_THINKING_DISABLED=false
